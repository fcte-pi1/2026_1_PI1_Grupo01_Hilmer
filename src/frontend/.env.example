# frontend/.env.example
# Copie para .env e ajuste conforme necessário

# URL base da API REST do backend
VITE_API_URL=http://localhost:3001

# URL do WebSocket do backend (para telemetria ao vivo)
VITE_WS_URL=ws://localhost:3001

# Modo de telemetria: 'mock' (sem hardware) | 'live' (ESP32 real)
VITE_TELEMETRY_MODE=mock
