# frontend/.env.example
# Copie para .env e ajuste conforme necessário.

# Base usada pelo frontend nas chamadas HTTP.
# Em desenvolvimento local, use /api para aproveitar o proxy do Vite.
VITE_API_BASE_URL=/api

# Destino do proxy do Vite para /api.
VITE_API_PROXY_TARGET=http://localhost:3001

# URL do WebSocket do backend para telemetria ao vivo.
VITE_WS_URL=ws://localhost:3001

# Modo de telemetria: mock (sem hardware) | live (ESP32 real)
VITE_TELEMETRY_MODE=mock
